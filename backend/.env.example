# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/ems?appName=Cluster0

# Server
PORT=5050
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
SALES_FRONTEND_URL=http://localhost:5174
FOLLOWUPS_FRONTEND_URL=http://localhost:5175
ALL_FRONTEND_URL=http://localhost:5176

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=12h

# Cloudinary (required for document/file storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (optional — if unset, "email link to employee" feature is simply hidden)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# LibreOffice (optional — only needed if `soffice` is not already on PATH)
SOFFICE_PATH=
